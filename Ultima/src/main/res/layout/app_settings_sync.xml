<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="?android:attr/listPreferredItemPaddingStart"
        android:paddingEnd="?android:attr/listPreferredItemPaddingEnd"
        android:paddingBottom="20dp"
        tools:background="@color/cardview_dark_background">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="5dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="App Settings &amp; Data Sync"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="5dp"
                android:contentDescription="Save"
                android:focusable="true" />
        </LinearLayout>

        <!-- Divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/divider_horizontal_dark" />

        <!-- Credentials Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Configure Credentials"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/app_settings_sync_creds_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="5dp"
                android:contentDescription="Edit"
                android:focusable="true" />
        </LinearLayout>

        <!-- Divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/divider_horizontal_dark" />

        <!-- Sync Switch 1: Backup Device -->
        <Switch
            android:id="@+id/backup_device"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup data to the cloud"
            android:textSize="17sp"
            android:padding="5dp"
            android:layout_marginVertical="5dp" />

        <!-- Sync Switch 2: Restore Device -->
        <Switch
            android:id="@+id/restore_device"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recover data from cloud"
            android:textSize="17sp"
            android:padding="5dp"
            android:layout_marginVertical="5dp" />

        <!-- Sync Now Button -->
        <Button
            android:id="@+id/sync_now_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sync Now (Force Sync)"
            android:textSize="16sp"
            android:layout_marginVertical="5dp"
            android:focusable="true" />

        <!-- Divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/divider_horizontal_dark" />

        <!-- Selective Sync Section: Backup -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select What to Backup"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp" />

        <CheckBox
            android:id="@+id/backup_bookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Bookmarks"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_resume_watching"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Resume Watching"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_search_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Search History"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_extensions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Extensions &amp; Repos"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_player"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Player Engine &amp; Seek"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_subtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Subtitle Style &amp; Fonts"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Theme &amp; Colors"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Poster Size &amp; Layout"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_downloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup Download Settings"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/backup_general"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backup General Settings"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <!-- Divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/divider_horizontal_dark" />

        <!-- Selective Sync Section: Restore -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select What to Restore"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp" />

        <CheckBox
            android:id="@+id/restore_bookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Bookmarks"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_resume_watching"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Resume Watching"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_search_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Search History"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_extensions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Extensions &amp; Repos"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_player"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Player Engine &amp; Seek"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_subtitles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Subtitle Style &amp; Fonts"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Theme &amp; Colors"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Poster Size &amp; Layout"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_downloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore Download Settings"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/restore_general"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restore General Settings"
            android:textSize="16sp"
            android:padding="5dp"
            android:focusable="true" />

        <!-- Divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/divider_horizontal_dark" />

        <!-- Device List Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Devices"
            android:textSize="18sp"
            android:layout_marginBottom="5dp" />

        <!-- Devices List -->
        <LinearLayout
            android:id="@+id/devices_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="10dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
